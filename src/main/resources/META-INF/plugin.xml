<idea-plugin>
    <id>io.github.anonim.aop-support</id>
    <name>AOP Support</name>
    <vendor>org.example</vendor>
    <description><![CDATA[
        AOP support for Spring AOP and AspectJ in Java projects.<br><br>
        Підтримка AOP (Aspect-Oriented Programming) для Spring AOP та AspectJ.<br><br>
        Функції:
        <ul>
            <li>Іконки на полях редактора (gutter icons) для аспектів та перехоплених методів</li>
            <li>Підсвічування AOP-анотацій (@Aspect, @Before, @After, @Around, @Pointcut)</li>
            <li>Навігація між аспектами та цільовими методами</li>
            <li>Інспекції для виявлення помилок у конфігурації AOP</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Plugin startup -->
        <projectActivity implementation="org.example.aop.AopPlugin"/>

        <!-- Native AspectJ `.aj` support -->
        <fileTypeFactory implementation="org.example.aop.aspectj.AspectJFileTypeFactory"/>
        <lang.parserDefinition language="AspectJ" implementationClass="org.example.aop.aspectj.AspectJParserDefinition"/>
        <lang.syntaxHighlighterFactory language="AspectJ" implementationClass="org.example.aop.aspectj.AspectJSyntaxHighlighterFactory"/>
        <annotator language="AspectJ" implementationClass="org.example.aop.aspectj.AspectJAnnotator"/>
        <psi.referenceContributor language="AspectJ" implementation="org.example.aop.aspectj.AspectJReferenceContributor"/>

        <!-- Phase 2: gutter icons -->
        <codeInsight.lineMarkerProvider
            language="JAVA"
            implementationClass="org.example.aop.marker.AopLineMarkerProvider"/>

        <!-- Phase 2: AOP annotation highlighting -->
        <annotator
            language="JAVA"
            implementationClass="org.example.aop.annotator.AopAnnotator"/>
        <annotator
            language="kotlin"
            implementationClass="org.example.aop.annotator.AopAnnotator"/>

        <!-- Phase 3: inspections -->
        <localInspection
            language="JAVA"
            shortName="AspectNotBean"
            displayName="@Aspect class is not a Spring Bean"
            groupName="AOP"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="org.example.aop.inspection.AspectNotBeanInspection"/>
        <localInspection
            language="kotlin"
            shortName="KotlinAspectNotBean"
            displayName="@Aspect class is not a Spring Bean"
            groupName="AOP"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="org.example.aop.inspection.KotlinAspectNotBeanInspection"/>

        <localInspection
            language="JAVA"
            shortName="PointcutSyntax"
            displayName="Invalid pointcut expression syntax"
            groupName="AOP"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="org.example.aop.inspection.PointcutSyntaxInspection"/>
        <localInspection
            language="kotlin"
            shortName="KotlinPointcutSyntax"
            displayName="Invalid pointcut expression syntax"
            groupName="AOP"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="org.example.aop.inspection.KotlinPointcutSyntaxInspection"/>

        <!-- Phase 3: code completion -->
        <completion.contributor
            language="JAVA"
            implementationClass="org.example.aop.completion.AopCompletionContributor"/>
        <completion.contributor
            language="kotlin"
            implementationClass="org.example.aop.completion.AopCompletionContributor"/>
        <completion.contributor
            language="AspectJ"
            implementationClass="org.example.aop.aspectj.AspectJCompletionContributor"/>

        <!-- Phase 4: tool window -->
        <!-- <toolWindow ... /> -->
    </extensions>

    <actions>
        <action
            id="org.example.aop.ai.actions.GeneratePointcutAction"
            class="org.example.aop.ai.actions.GeneratePointcutAction"
            text="Generate Pointcut with AI"
            description="Generate pointcut expression from natural language description">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="org.example.aop.ai.actions.ExplainPointcutAction"
            class="org.example.aop.ai.intentions.ExplainPointcutIntention"
            text="Explain Pointcut with AI"
            description="Explain the selected pointcut or AspectJ snippet with AI">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="org.example.aop.ai.actions.OptimizePointcutAction"
            class="org.example.aop.ai.intentions.OptimizePointcutIntention"
            text="Optimize Pointcut with AI"
            description="Optimize the selected pointcut or AspectJ snippet with AI">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
            id="org.example.aop.ai.actions.FixPointcutAction"
            class="org.example.aop.ai.actions.FixPointcutAction"
            text="Fix with AI"
            description="Fix the selected pointcut or AspectJ snippet with AI">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
